<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5FA"
    android:orientation="vertical"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══ Tenda Header ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="16dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#0D47A1"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="Tenda Router"
                        android:src="@drawable/ic_launcher_foreground"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Router Tool"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="192.168.0.1"
                            android:textColor="#90CAF9"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ Status ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStatusBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="12dp"
                app:strokeColor="#EEEEF2"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <View
                        android:id="@+id/dotStatus"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="#BDBDBD"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ready"
                        android:textColor="#8E8E9A"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ Menu Grid ═══ -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="2"
                android:columnOrderPreserved="false"
                android:horizontalSpacing="12dp"
                android:rowOrderPreserved="false"
                android:verticalSpacing="12dp">

                <!-- 1. Restart -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnRestart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="true"
                    android:clickable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="#EEEEF2"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:focusable="false">
                        <LinearLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/circle_restart"
                            android:gravity="center"
                            android:focusable="false">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔄"
                                android:textSize="20sp"
                                android:focusable="false" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Restart"
                            android:textColor="#1A1A2E"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:focusable="false" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Router"
                            android:textColor="#8E8E9A"
                            android:textSize="11sp"
                            android:focusable="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 2. Check Connection -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="true"
                    android:clickable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="#EEEEF2"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:focusable="false">
                        <LinearLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/circle_status"
                            android:gravity="center"
                            android:focusable="false">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🌐"
                                android:textSize="20sp"
                                android:focusable="false" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Check"
                            android:textColor="#1A1A2E"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:focusable="false" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Connection"
                            android:textColor="#8E8E9A"
                            android:textSize="11sp"
                            android:focusable="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 3. Info Router -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="true"
                    android:clickable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="#EEEEF2"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:focusable="false">
                        <LinearLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/circle_info"
                            android:gravity="center"
                            android:focusable="false">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ℹ️"
                                android:textSize="20sp"
                                android:focusable="false" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Info"
                            android:textColor="#1A1A2E"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:focusable="false" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Router"
                            android:textColor="#8E8E9A"
                            android:textSize="11sp"
                            android:focusable="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 4. Devices -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnDevices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="true"
                    android:clickable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="#EEEEF2"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:focusable="false">
                        <LinearLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/circle_device"
                            android:gravity="center"
                            android:focusable="false">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📱"
                                android:textSize="20sp"
                                android:focusable="false" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Devices"
                            android:textColor="#1A1A2E"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:focusable="false" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Connected"
                            android:textColor="#8E8E9A"
                            android:textSize="11sp"
                            android:focusable="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 5. Web Admin -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnWeb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="true"
                    android:clickable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="#EEEEF2"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:focusable="false">
                        <LinearLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/circle_web"
                            android:gravity="center"
                            android:focusable="false">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🌍"
                                android:textSize="20sp"
                                android:focusable="false" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Web Admin"
                            android:textColor="#1A1A2E"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:focusable="false" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Settings"
                            android:textColor="#8E8E9A"
                            android:textSize="11sp"
                            android:focusable="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 6. Scan -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnScan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="true"
                    android:clickable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="#EEEEF2"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:focusable="false">
                        <LinearLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/circle_scan"
                            android:gravity="center"
                            android:focusable="false">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="\uD83D\uDD0D"
                                android:textSize="20sp"
                                android:focusable="false" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Scan"
                            android:textColor="#1A1A2E"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:focusable="false" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Network"
                            android:textColor="#8E8E9A"
                            android:textSize="11sp"
                            android:focusable="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 7. Password -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="true"
                    android:clickable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="#EEEEF2"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:focusable="false">
                        <LinearLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/circle_password"
                            android:gravity="center"
                            android:focusable="false">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔑"
                                android:textSize="20sp"
                                android:focusable="false" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Password"
                            android:textColor="#1A1A2E"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:focusable="false" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Admin"
                            android:textColor="#8E8E9A"
                            android:textSize="11sp"
                            android:focusable="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- ═══ Password Form ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPasswordForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardElevation="0dp"
                app:cardCornerRadius="16dp"
                app:strokeColor="#EEEEF2"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔑 Change Password"
                        android:textColor="#1A1A2E"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:hint="New password">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:hint="Confirm">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputPassword2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSavePassword"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="14dp"
                        android:backgroundTint="#0D47A1"
                        android:text="Save"
                        android:textAllCaps="false"
                        android:textSize="15sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="Router Tool · Tenda"
                android:textColor="#C0C0C8"
                android:textSize="11sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
